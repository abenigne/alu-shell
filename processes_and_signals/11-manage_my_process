#!/usr/bin/env bash
# Manages the manage_my_process daemon: start, stop, or restart it

PID_FILE="/var/run/my_process.pid"
SCRIPT_DIR="$(dirname "$0")"
DAEMON="$SCRIPT_DIR/manage_my_process"

start() {
"$DAEMON" &
echo "$!" > "$PID_FILE"
}

stop() {
kill "$(cat "$PID_FILE")"
rm -f "$PID_FILE"
}

case "$1" in
start)
start
echo "manage_my_process started"
;;
stop)
stop
echo "manage_my_process stopped"
;;
restart)
stop
start
echo "manage_my_process restarted"
;;
*)
echo "Usage: manage_my_process {start|stop|restart}"
;;
esac
